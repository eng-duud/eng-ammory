generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── PROJECTS ──────────────────────────────────────────────────
model Project {
  id          String   @id @default(cuid())
  title       String
  titleEn     String?
  slug        String   @unique
  description String
  descriptionLong String?
  coverImage  String?          // Cloudinary URL
  images      ProjectImage[]   // gallery
  tech        ProjectTech[]
  categoryId  String
  category    Category  @relation(fields: [categoryId], references: [id])
  liveUrl     String?
  githubUrl   String?
  featured    Boolean  @default(false)
  hidden      Boolean  @default(false)
  order       Int      @default(0)
  color       String   @default("#1a3a5c")
  accent      String   @default("#4a9eff")
  year        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ProjectImage {
  id        String  @id @default(cuid())
  url       String
  alt       String?
  order     Int     @default(0)
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ProjectTech {
  id        String  @id @default(cuid())
  name      String
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ─── CATEGORIES ────────────────────────────────────────────────
model Category {
  id       String    @id @default(cuid())
  name     String    // e.g. "Full-Stack"
  slug     String    @unique // e.g. "fullstack"
  order    Int       @default(0)
  projects Project[]
}

// ─── SKILLS ────────────────────────────────────────────────────
model Skill {
  id         String        @id @default(cuid())
  name       String
  level      Int           @default(80)  // 0-100
  order      Int           @default(0)
  groupId    String
  group      SkillGroup    @relation(fields: [groupId], references: [id])
}

model SkillGroup {
  id     String  @id @default(cuid())
  name   String  // e.g. "Frontend"
  slug   String  @unique
  order  Int     @default(0)
  skills Skill[]
}

// ─── EXPERIENCE ────────────────────────────────────────────────
model Experience {
  id          String   @id @default(cuid())
  role        String
  company     String
  period      String
  description String
  tech        String[] // array of tech names
  order       Int      @default(0)
}

// ─── STATS ─────────────────────────────────────────────────────
model Stat {
  id     String @id @default(cuid())
  label  String
  value  Int
  suffix String @default("+")
  order  Int    @default(0)
}

// ─── SITE SETTINGS ─────────────────────────────────────────────
model Setting {
  key   String @id
  value String
}

// ─── MESSAGES (Contact Form) ───────────────────────────────────
model Message {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String?
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}
